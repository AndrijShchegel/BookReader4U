<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginEnd="24dp"
    android:layout_marginTop="18dp"
    android:padding="8dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_search_book_cover"
        android:layout_width="100dp"
        android:layout_height="160dp"
        android:adjustViewBounds="true"
        android:contentDescription="@string/image_description_book_cover"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/RoundedSquare"
        tools:src="@drawable/book_cover" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        app:layout_constraintStart_toStartOf="@id/iv_search_book_cover"
        app:layout_constraintEnd_toEndOf="@id/iv_search_book_cover"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tv_search_book_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:ellipsize="end"
        android:lineSpacingExtra="2sp"
        android:maxLines="2"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/iv_search_book_cover"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Call of the Sirens: A Tale of Mystery and Adventure" />

    <TextView
        android:id="@+id/tv_search_author"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/iv_search_book_cover"
        app:layout_constraintTop_toBottomOf="@id/tv_search_book_title"
        tools:text="K. B. Benson" />

    <TextView
        android:id="@+id/tv_search_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        android:maxLines="3"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/iv_search_book_cover"
        app:layout_constraintTop_toBottomOf="@id/tv_search_author"
        tools:text="Hello Adw\n I'm here\n to tell\n you" />

    <RatingBar
        android:id="@+id/rb_search_rating"
        style="@style/Widget.AppCompat.RatingBar.Small"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:progressTint="@color/rating_bar_tint"
        android:stepSize="0.1"
        app:layout_constraintStart_toEndOf="@id/iv_search_book_cover"
        app:layout_constraintTop_toBottomOf="@id/tv_search_description"
        tools:rating="4.5" />

    <TextView
        android:id="@+id/tv_search_rating_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="6dp"
        app:layout_constraintStart_toEndOf="@id/rb_search_rating"
        app:layout_constraintTop_toBottomOf="@id/tv_search_description"
        tools:text="(100 ratings)" />


</androidx.constraintlayout.widget.ConstraintLayout>

