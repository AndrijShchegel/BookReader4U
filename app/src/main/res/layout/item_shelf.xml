<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:layout_marginTop="24dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/shelf_touch"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:foreground="?attr/selectableItemBackground"
        app:layout_constraintEnd_toStartOf="@id/btn_delete_shelf"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_shelf_book_cover"
            android:layout_width="64dp"
            android:layout_height="100dp"
            android:contentDescription="@string/image_description_book_cover"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@drawable/book_cover" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/iv_shelf_book_cover"
            app:layout_constraintEnd_toEndOf="@id/iv_shelf_book_cover"
            app:layout_constraintStart_toStartOf="@id/iv_shelf_book_cover"
            app:layout_constraintTop_toTopOf="@id/iv_shelf_book_cover" />

        <TextView
            android:id="@+id/tv_shelf_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:maxLines="2"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/tv_shelf_author"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/iv_shelf_book_cover"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Call of the Sirens" />

        <TextView
            android:id="@+id/tv_shelf_author"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:textColor="@color/gray"
            android:textSize="18sp"
            app:layout_constraintBottom_toTopOf="@id/pb_shelf"
            app:layout_constraintStart_toEndOf="@id/iv_shelf_book_cover"
            app:layout_constraintTop_toBottomOf="@id/tv_shelf_title"
            tools:text="K. B. Benson" />

        <ProgressBar
            android:id="@+id/pb_shelf"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="152dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:progressBackgroundTint="?attr/colorPrimaryContainer"
            android:progressDrawable="@drawable/progress_bar_bg_for_display_ratings"
            android:progressTint="?attr/colorPrimary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/iv_shelf_book_cover"
            app:layout_constraintTop_toBottomOf="@id/tv_shelf_author"
            app:trackThickness="1dp"
            tools:progress="39" />

        <TextView
            android:id="@+id/tv_shelf_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/pb_shelf"
            app:layout_constraintTop_toBottomOf="@id/tv_shelf_author"
            tools:text="39%" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_delete_shelf"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:contentDescription="Видалити полицю"
        android:insetLeft="0dp"
        android:insetTop="0dp"
        android:insetRight="0dp"
        android:insetBottom="0dp"
        app:icon="@drawable/delete_forever_24"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>