<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@color/light_gray"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_display_theme"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Тема"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/theme_light"
        android:layout_width="64dp"
        android:layout_height="48dp"
        android:layout_marginTop="4dp"
        android:backgroundTint="@color/white"
        android:contentDescription="Світла тема"
        android:theme="@style/Widget.Material3.Button.OutlinedButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_display_theme" />

    <Button
        android:id="@+id/theme_sepia"
        android:layout_width="64dp"
        android:layout_height="48dp"
        android:layout_marginHorizontal="8dp"
        android:backgroundTint="#faf4e8"
        android:contentDescription="Сепія"
        android:theme="@style/Widget.Material3.Button.OutlinedButton"
        app:layout_constraintEnd_toStartOf="@id/theme_dark"
        app:layout_constraintStart_toEndOf="@id/theme_light"
        app:layout_constraintTop_toTopOf="@id/theme_light" />

    <Button
        android:id="@+id/theme_dark"
        android:layout_width="64dp"
        android:layout_height="48dp"
        android:backgroundTint="@color/black"
        android:contentDescription="Темна тема"
        android:theme="@style/Widget.Material3.Button.OutlinedButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/theme_light" />

    <TextView
        android:id="@+id/tv_display_text_size_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Шрифт"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/theme_light" />


    <com.google.android.material.button.MaterialButton
        android:id="@+id/less_size"
        android:layout_width="64dp"
        android:layout_height="48dp"
        android:layout_marginTop="4dp"
        android:contentDescription="Зменшити шрифт"
        app:icon="@drawable/text_size_decrease"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_display_text_size_title" />

    <TextView
        android:id="@+id/tv_display_text_size"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@id/more_size"
        app:layout_constraintEnd_toStartOf="@id/more_size"
        app:layout_constraintStart_toEndOf="@id/less_size"
        app:layout_constraintTop_toTopOf="@id/less_size"
        tools:text="100%" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/more_size"
        android:layout_width="64dp"
        android:layout_height="48dp"
        android:layout_marginStart="18dp"
        android:contentDescription="Збільшити шрифт"
        app:icon="@drawable/text_size_increase"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/less_size" />


    <TextView
        android:id="@+id/tv_display_line_height_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Міжрядковий інтервал"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/less_size" />


    <com.google.android.material.button.MaterialButton
        android:id="@+id/less_line_height"
        android:layout_width="64dp"
        android:layout_height="48dp"
        android:layout_marginTop="4dp"
        android:contentDescription="Зменшити міжрядковий інтервал"
        app:icon="@drawable/line_spacing_increase"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_display_line_height_title" />

    <TextView
        android:id="@+id/tv_display_line_height"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@id/more_line_height"
        app:layout_constraintEnd_toStartOf="@id/more_line_height"
        app:layout_constraintStart_toEndOf="@id/less_line_height"
        app:layout_constraintTop_toTopOf="@id/less_line_height"
        tools:text="100%" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/more_line_height"
        android:layout_width="64dp"
        android:layout_height="48dp"
        android:contentDescription="Збільшити міжрядковий інтервал"
        app:icon="@drawable/line_spacing_decrease"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/less_line_height" />

</androidx.constraintlayout.widget.ConstraintLayout>